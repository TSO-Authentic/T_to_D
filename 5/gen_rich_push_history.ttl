setdlgpos 500 200;
;-----------------------------------------------------
; サブルーチン用引数戻り値定義
; tera termマクロは引数と戻り値が指定できないため
;-----------------------------------------------------
sshHost = ""
sshPW = ""
;-----------------------------------------------------
; 定数定義
;-----------------------------------------------------
getenv 'W3ITDB12' W3ITDB12
getenv 'PW_ORACLE' PW_ORACLE
getenv 'ACCOUNT_ID' ACCOUNT_ID
CRLF = #13#10

;-----------------------------------------------------
; メイン処理
; ----------------------------------------------------

; ----------------------------------------------------
;  w3itdb12
; ----------------------------------------------------
;接続
getenv 'OUTPUT_FILE' outputPath

sshHost = W3ITDB12
call connectSshOracle

;SQLPlus実行
sendln "sqlplus -s wb3913/wb3913@WBRK31"
logopen outputPath 0 1
sendln "set pagesize 0"
sendln CRLF

sendln "-- GEN_RICH_PUSH_HISTORYエラー件数確認（株）▼▼▼▼▼▼▼▼▼▼▼▼▼▼▼▼"
inputstr = "select count(1) from GEN_RICH_PUSH_HISTORY where account_id = '"
strconcat inputstr ACCOUNT_ID
strconcat inputstr "' and status not in (1,6,7);"
sendln inputstr
mpause 200
sendln "exit;"

call judgeExit

unlink

end

logclose

;-----------------------------------------------------
; サブルーチン
;   引数、戻り値をグローバル変数で宣言する必要がある。
;   コーディングミスをしない為、下記のルールを使用する。
;       引数：メソッドの最後で初期化
;       戻り値：メソッドの最初で初期化
;-----------------------------------------------------

;ssh接続
:connectSsh
    ;文字列を継ぎ足す。 
	ssh = ""
	strconcat ssh sshHost
	strconcat ssh sshPW
	;ssh接続
	connect ssh
	wait "Last login"
	
	;引数の初期化
	sshHost = ""
	sshPW = ""
return

;oracleへ接続
:connectSshOracle
    sshPW = PW_ORACLE
    call connectSsh
    call waitOracle
return

;oracleユーザwait	
:waitOracle	
	mpause 300
	wait '[oracle@'
return	

:judgeExit			
	for i 1 7		
		recvln
		Str_recvln = inputstr	
	next
	str_text = "echo Result count is " 
	strconcat str_text Str_recvln
	sendln str_text
	sendln "exit"
return


