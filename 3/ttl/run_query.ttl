setdlgpos 500 200;
;-----------------------------------------------------
; サブルーチン用引数戻り値定義
; tera termマクロは引数と戻り値が指定できないため
;-----------------------------------------------------
sshHost = ""
sshPW = ""
;-----------------------------------------------------
; 定数定義
;-----------------------------------------------------
getenv 'W3ITDB12' W3ITDB12
getenv 'PW_ORACLE' PW_ORACLE
getenv 'ACCOUNT_ID' ACCOUNT_ID
CRLF = #13#10

RUNIGN_STR='0'

;-----------------------------------------------------
; メイン処理
; ----------------------------------------------------

; ----------------------------------------------------
;  w3itdb12
; ----------------------------------------------------
;接続
getenv 'OUTPUT_FILE' outputPath

sshHost = W3ITDB12
call connectSshOracle

;SQLPlus実行
sendln "sqlplus -s wb3913/wb3913@WBRK31"
logopen outputPath 0 1
sendln "set pagesize 0"
sendln CRLF

inputstr = "SELECT item_contents FROM (SELECT * FROM EXT_MAIL_PROC WHERE account_code = '1164775' AND sendmail_div = '4002' AND item_name = 'auth_code' ORDER BY mail_id DESC) WHERE ROWNUM < 2;"
sendln inputstr
mpause 200
sendln "exit;"

call judgeExit

unlink

end

logclose

;ssh接続
:connectSsh
    ;文字列を継ぎ足す。 
	ssh = ""
	strconcat ssh sshHost
	strconcat ssh sshPW
	;ssh接続
	connect ssh
	wait "Last login"
	
	;引数の初期化
	sshHost = ""
	sshPW = ""
return

:commonlibrary
return 

;oracleへ接続
:connectSshOracle
    sshPW = PW_ORACLE
    call connectSsh
    call waitOracle
return

;oracleユーザwait	
:waitOracle	
	mpause 300
	wait '[oracle@'
return	

:judgeExit			
	for i 1 6		
		recvln
		Str_recvln = inputstr	
	next
	str_text = "echo Result count is " 
	strconcat str_text Str_recvln
	sendln str_text
	sendln "exit"
return