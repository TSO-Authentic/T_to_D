setdlgpos 500 200
;-----------------------------------------------------
; サブルーチン用引数戻り値定義
; tera termマクロは引数と戻り値が指定できないため
;-----------------------------------------------------
sshHost = ""
sshPW = ""
strCheck = ""
commandLine = 'echo "$(ls -t /cmn/log/inf/script/COM_INF_UN_JBOSS_CTL* | head -1 | xargs sed -n 8p)"'
;-----------------------------------------------------
; 定数定義
;-----------------------------------------------------
getenv 'SERVER_START_CHECK' server_startcheck

getenv 'W3ITAP12' W3ITAP12
getenv 'PW_JBOSS' PW_JBOSS
CRLF = #13#10

;-----------------------------------------------------
; メイン処理
; ----------------------------------------------------
;  下記の順でssh接続し稼働確認を行う。
;  w3itwb12 ⇒ w3itap12 ⇒ w3itdb12
;-----------------------------------------------------

; ----------------------------------------------------
;  w3itap12
; ----------------------------------------------------
;接続
sshHost = W3ITAP12
call connectSshJboss

getenv 'OUTPUT_FILE' outputPath
logopen outputPath 0 1

;AP起動確認（株）
sendln ": AP起動確認（株）▼▼▼▼▼▼▼▼▼▼▼▼▼▼▼▼▼" CRLF
call waitJboss
sendln "/cmn/inf/script/COM_INF_UN_JBOSS_CTL.bash online jboss06ap"
mpause 100
call waitJboss
sendln "ls -t /cmn/log/inf/script/COM_INF_UN_JBOSS_CTL* | head -1 | xargs cat >> /home/jboss/ls_uat/jboss06ap_test.log 2>&1"
mpause 100
call waitJboss
call checkString

sendln "exit"

sendln ": AP起動確認（株）▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲▲" CRLF

unlink

end
logclose

;-----------------------------------------------------				
; サブルーチン				
;   引数、戻り値をグローバル変数で宣言する必要がある。				
;   コーディングミスをしない為、下記のルールを使用する。				
;       引数：メソッドの最後で初期化				
;       戻り値：メソッドの最初で初期化				
;-----------------------------------------------------

;ssh接続				
:connectSsh				
	;文字列を継ぎ足す。 			
	ssh = ""			
	strconcat ssh sshHost			
	strconcat ssh sshPW			
	;ssh接続			
	connect ssh			
	wait "Last login"			
				
	;引数の初期化			
	sshHost = ""			
	sshPW = ""			
return				

;jbossへ接続				
:connectSshJboss				
	sshPW = PW_JBOSS			
	call connectSsh			
	call waitJboss			
return

;jbossユーザwait
:waitJboss
	mpause 100
	wait '[jboss@'
return

:checkString
	sendln commandLine
	wait "COM_L1903"
	recvln
	strCheck = inputstr
    strmatch strCheck server_startcheck
    if result<> 0 then
        sendln "echo The checkString has been successfully matched." 
    endif
return