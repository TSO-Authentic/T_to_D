setdlgpos 500 200
;-----------------------------------------------------
; サブルーチン用引数戻り値定義
; tera termマクロは引数と戻り値が指定できないため
;-----------------------------------------------------
sshHost = ""
sshPW = ""

;-----------------------------------------------------
; 定数定義
;-----------------------------------------------------
getenv 'W3ITDB12' W3ITDB12
getenv 'PW_WBRK3' PW_WBRK3
CRLF = #13#10

;-----------------------------------------------------
; メイン処理
; ----------------------------------------------------
;  下記の順でssh接続し稼働確認を行う。
;  w3itwb12 ⇒ w3itap12 ⇒ w3itdb12
;-----------------------------------------------------

; ----------------------------------------------------
;  w3itdb12
; ----------------------------------------------------
;接続
sshHost = W3ITDB12
call connectSshWbrk3
getenv 'OUTPUT_FILE' outputPath

;SQLPlus実行
sendln "sqlplus -s wb3913/wb3913@WBRK31"
logopen outputPath 0 1
sendln "set pagesize 0"
sendln ""

;日付確認
sendln "-- 日付確認（株）▼▼▼▼▼▼▼▼▼▼▼▼▼▼▼▼"
sendln "SELECT 'DB時間' AS 区分,TO_CHAR(SYSDATE + (SELECT VALUE FROM SYSTEM_PREFERENCES WHERE NAME='shift.system.timestamp.millisecs')/1000/60/60/24,'yyyy/mm/dd hh24:mi:ss') AS 値 FROM DUAL"
sendln "union all"
sendln "SELECT NAME, VALUE FROM SYSTEM_PREFERENCES WHERE NAME = 'system.bizdate';"
wait 'system.bizdate'
mpause 100

sendln "exit;"

call judgeDateExit

unlink

end
logclose

;-----------------------------------------------------				
; サブルーチン				
;   引数、戻り値をグローバル変数で宣言する必要がある。				
;   コーディングミスをしない為、下記のルールを使用する。				
;       引数：メソッドの最後で初期化				
;       戻り値：メソッドの最初で初期化				
;-----------------------------------------------------

;ssh接続				
:connectSsh				
	;文字列を継ぎ足す。 			
	ssh = ""			
	strconcat ssh sshHost			
	strconcat ssh sshPW			
	;ssh接続			
	connect ssh			
	wait "Last login"			
				
	;引数の初期化			
	sshHost = ""			
	sshPW = ""			
return				

;wbrk3へ接続	
:connectSshWbrk3	
	sshPW = PW_WBRK3
	call connectSsh
	call waitWbrk3
return	

;wbrk3ユーザwait	
:waitWbrk3	
	mpause 100
	wait '[wbrk3@'
return	
			
:judgeDateExit					
			
	for i 1 6		
		recvln	
		Str_recvln = inputstr	
	next		
			
	call waitWbrk3 
	str_text = "echo 'system.bizdate' is '" 
	strconcat str_text Str_recvln
	strconcat str_text "'"
	sendln str_text		
	sendln "exit"
return			
