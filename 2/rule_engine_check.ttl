setdlgpos 500 200
;-----------------------------------------------------
; サブルーチン用引数戻り値定義
; tera termマクロは引数と戻り値が指定できないため
;-----------------------------------------------------
sshHost = ""
sshPW = ""

;-----------------------------------------------------
; 定数定義
;-----------------------------------------------------
getenv 'W3ITAP12' W3ITAP12
getenv 'PW_JBOSS' PW_JBOSS
CRLF = #13#10

;-----------------------------------------------------
; メイン処理
; ----------------------------------------------------
;  下記の順でssh接続し稼働確認を行う。
;  w3itwb12 ⇒ w3itap12 ⇒ w3itdb12
;-----------------------------------------------------

; ----------------------------------------------------
;  w3itap12
; ----------------------------------------------------
;接続
sshHost = W3ITAP12
call connectSshJboss
getenv 'OUTPUT_FILE' outputPath

;ルールエンジン起動確認（株）
logopen outputPath 0 1
sendln ": ルールエンジン起動確認（株）▼▼▼▼▼▼▼▼▼▼▼" CRLF
call waitJboss
sendln "cd /app/wb3/rule-engine/bin/"
call waitJboss
sendln "./checkproc_HealthCheck.csh"
call waitJboss
mpause 100
sendln "exit"

sendln ": ルールエンジン起動確認（株）▲▲▲▲▲▲▲▲▲▲▲" CRLF

unlink

end
logclose

;-----------------------------------------------------				
; サブルーチン				
;   引数、戻り値をグローバル変数で宣言する必要がある。				
;   コーディングミスをしない為、下記のルールを使用する。				
;       引数：メソッドの最後で初期化				
;       戻り値：メソッドの最初で初期化				
;-----------------------------------------------------

;ssh接続				
:connectSsh				
	;文字列を継ぎ足す。 			
	ssh = ""			
	strconcat ssh sshHost			
	strconcat ssh sshPW			
	;ssh接続			
	connect ssh			
	wait "Last login"			
				
	;引数の初期化			
	sshHost = ""			
	sshPW = ""			
return				

;jbossへ接続				
:connectSshJboss				
	sshPW = PW_JBOSS			
	call connectSsh			
	call waitJboss			
return

;jbossユーザwait
:waitJboss
	mpause 100
	wait '[jboss@'
return		
