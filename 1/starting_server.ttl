setdlgpos 500 200

sshHost = ""
sshPW = ""

getenv 'SERVER_START_CHECK' server_startcheck

getenv 'W3ITAP12' W3ITAP12
getenv 'PW_JBOSS' PW_JBOSS

sshHost = W3ITAP12
call connectSshJboss

getenv 'OUTPUT_FILE' outputPath
logopen outputPath 0 1

call waitJboss
sendln "/cmn/inf/script/COM_INF_UN_JBOSS_CTL.bash start jboss06ap"

call waitJboss
sendln "/cmn/inf/script/COM_INF_UN_JBOSS_CTL.bash online jboss06ap"

call waitJboss
sendln "ls -t /cmn/log/inf/script/COM_INF_UN_JBOSS_CTL* | head -1 | xargs cat"

call checkString

sendln "exit"

unlink
end
logclose

;ssh接続				
:connectSsh				
	;文字列を継ぎ足す。 			
	ssh = ""			
	strconcat ssh sshHost			
	strconcat ssh sshPW			
	;ssh接続			
	connect ssh			
	wait "Last login"			
				
	;引数の初期化			
	sshHost = ""			
	sshPW = ""			
return	

;jbossへ接続				
:connectSshJboss				
	sshPW = PW_JBOSS
	call connectSsh		
return

;jbossユーザwait
:waitJboss
	mpause 100
	wait '[jboss@'
return

:checkString
	for i 1 9	
		recvln
		Str_recvln = inputstr	
	next

    strmatch Str_recvln server_startcheck
    if result<> 0 then
            sendln "echo The checkString has been successfully matched." 
        endif
return